# AI Hub — Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=dein_bot_token_hier
TELEGRAM_CHAT_ID=deine_chat_id_hier

# ── Modelle ──────────────────────────────────────────────────────────────────
# Dispatcher: klein + tool-use-fähig, läuft auf CPU
DISPATCHER_MODEL=glm4:9b

# Chat-Skill: Standard-Modell für Gespräche
CHAT_MODEL=qwen3-coder-next

# Builder-Modi werden im Builder selbst konfiguriert (MODES dict)

# ── Verzeichnisse ────────────────────────────────────────────────────────────
# Output-Verzeichnis für Builder-Projekte
OUTPUT_DIR=./output

# Download-Zielverzeichnis
DOWNLOAD_DIR=C:\Users\DEIN_NAME\Downloads

# ── Steam (optional) ─────────────────────────────────────────────────────────
# Für Steam-Downloads via steamcmd
STEAM_USER=anonymous
STEAM_PASS=

# ── ComfyUI (optional) ───────────────────────────────────────────────────────
# URL zur laufenden ComfyUI-Instanz
COMFYUI_URL=http://localhost:8188

# ── Knowledge System (RAG) ─────────────────────────────────────────────
# Folders to watch for auto-indexing (comma-separated)
# KNOWLEDGE_WATCH_DIRS=C:\Users\DEIN_NAME\Documents,C:\Users\DEIN_NAME\Desktop

# ── Audio (Voicebox TTS/STT) ──────────────────────────────────────────
# Voicebox server URL (Qwen3-TTS + Whisper-large)
VOICEBOX_URL=http://127.0.0.1:17493
# Timeout for Voicebox API calls in seconds
# VOICEBOX_TIMEOUT=120
# Path to Voicebox installation (for auto-start)
# VOICEBOX_PATH=C:\Program Files\Voicebox

# ── Builder Docker ───────────────────────────────────────────────────────────
BUILDER_IMAGE=ai-cluster

# ── Self-Optimizer ──────────────────────────────────────────────────────────
# Agent-Timeouts in Sekunden
# OPT_DEVELOPER_TIMEOUT=300
# OPT_TESTER_TIMEOUT=120
# OPT_REVIEWER_TIMEOUT=180
# OPT_TEST_TIMEOUT=60
# Fehler-Limits
# OPT_MAX_CONSEC_ERRORS=3
# OPT_MAX_TOTAL_ERRORS=10
# OPT_MAX_ITERATIONS=100
# Docker-Ressourcen
# OPT_CONTAINER_MEMORY=512m
# OPT_CONTAINER_CPU=2
# Standard-Modelle (werden im Wizard ueberschrieben)
# OPT_REASONING_MODEL=deepseek-r1:32b
# OPT_CODING_MODEL=qwen3-coder-next
