# AI Hub environment variables
# Copy this file to .env and fill in your own values.

# Telegram
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Paths
DOWNLOAD_DIR=C:\Users\YourName\Downloads
OUTPUT_DIR=output

# Models
DISPATCHER_MODEL=glm-4-flash
CHAT_MODEL=qwen2.5:7b
BUILDER_REVIEW_MODEL=

# Builder / services
BUILDER_IMAGE=ai-cluster
VOICEBOX_URL=http://127.0.0.1:17493
VOICEBOX_TIMEOUT=120
VOICEBOX_PATH=C:\Program Files\Voicebox
COMFYUI_URL=http://localhost:8188
KNOWLEDGE_WATCH_DIRS=

# LLM / pipeline tuning
LLM_TIMEOUT=1800
LLM_RETRIES=4
BUILDER_SKIP_POLISH=false
TRIGGERED_BY=

# Self-optimizer defaults
OPT_DEVELOPER_TIMEOUT=300
OPT_TESTER_TIMEOUT=120
OPT_REVIEWER_TIMEOUT=180
OPT_TEST_TIMEOUT=60
OPT_MAX_CONSEC_ERRORS=5
OPT_MAX_TOTAL_ERRORS=15
OPT_MAX_ITERATIONS=100
OPT_CONTAINER_MEMORY=512m
OPT_CONTAINER_CPU=2
OPT_REASONING_MODEL=deepseek-r1:32b
OPT_CODING_MODEL=qwen3-coder-next
